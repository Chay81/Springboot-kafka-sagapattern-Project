{
  "dashboard": {
    "id": null,
    "uid": "spring-boot-jvm",
    "title": "Spring Boot JVM Metrics",
    "tags": [
      "spring",
      "jvm",
      "micrometer"
    ],
    "timezone": "browser",
    "panels": [
      {
        "type": "graph",
        "title": "JVM Memory Usage",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "jvm_memory_used_bytes{area=\"heap\"}",
            "legendFormat": "{{id}}",
            "interval": "",
            "refId": "A"
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 0,
          "w": 12,
          "h": 8
        }
      },
      {
        "type": "graph",
        "title": "HTTP Request Duration",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "rate(http_server_requests_seconds_sum{uri!=\"/actuator/prometheus\"}[1m]) / rate(http_server_requests_seconds_count{uri!=\"/actuator/prometheus\"}[1m])",
            "legendFormat": "{{uri}}",
            "interval": "",
            "refId": "B"
          }
        ],
        "gridPos": {
          "x": 12,
          "y": 0,
          "w": 12,
          "h": 8
        }
      },
      {
        "type": "stat",
        "title": "Active Threads",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "jvm_threads_live_threads",
            "refId": "C"
          }
        ],
        "gridPos": {
          "x": 0,
          "y": 8,
          "w": 6,
          "h": 5
        }
      },
      {
        "type": "stat",
        "title": "CPU Usage (Process)",
        "datasource": "Prometheus",
        "targets": [
          {
            "expr": "process_cpu_usage",
            "refId": "D"
          }
        ],
        "gridPos": {
          "x": 6,
          "y": 8,
          "w": 6,
          "h": 5
        }
      }
    ],
    "schemaVersion": 37,
    "version": 1,
    "refresh": "10s"
  },
  "overwrite": true
}